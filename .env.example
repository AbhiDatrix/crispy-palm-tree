# ============================================
# Datrix WhatsApp Bot — Environment Variables
# ============================================

# Groq API Key (free at https://console.groq.com)
GROQ_API_KEY= "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"

# Your WhatsApp number (with country code, no + sign)
# This number gets admin privileges (broadcast, etc.)
ADMIN_NUMBER=+919876543210

# Bot display name (used in system prompts)
BOT_NAME=Robert

# Dashboard port
PORT=3000

# ============================================
# Message Monitoring Configuration
# ============================================

# Enable message monitoring (captures all messages, calls, media)
MONITORING_ENABLED=false

# Data retention period in days (default: 30)
MONITOR_RETENTION_DAYS=30

# Save media files to disk (images, videos, audio, documents)
MONITOR_SAVE_MEDIA=true

# ============================================
# News API Configuration
# ============================================

# GNews API (Get free key from https://gnews.io/)
# Free tier: 100 requests/day
GNEWS_API_KEY=your_gnews_api_key_here
